---
const cards = [
  { ic: '🦀', t: 'Rust-grade parsing', d: "Each format's parser is written in Rust and compiled to WebAssembly — fast, memory-safe, and faithful to ECMA-376 / ISO-29500." },
  { ic: '🎨', t: 'Canvas, not the DOM', d: "Rendered with the Canvas 2D API on the main thread, sharing the document's font set — so text metrics, wrapping, and page breaks match Office." },
  { ic: '📐', t: 'Spec-faithful, not guessed', d: 'docGrid snapping, line-spacing rules, theme colour modifiers, chart axis styling — implemented from the spec, never from per-sample heuristics.' },
  { ic: '🧩', t: 'Headless or batteries-included', d: 'Use the built-in viewers, or drive the headless engine into your own scroll views, thumbnail grids, and master–detail panes.' },
];
---
<div class="pitch-grid">
  {cards.map((c) => (
    <div class="pitch-card">
      <div class="pitch-ic">{c.ic}</div>
      <h3>{c.t}</h3>
      <p>{c.d}</p>
    </div>
  ))}
</div>

<style>
  .pitch-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .pitch-card {
    padding: 22px 20px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg-elev);
    transition: border-color 0.2s, transform 0.2s;
  }
  .pitch-card:hover { border-color: var(--border-bright); transform: translateY(-2px); }
  .pitch-ic { font-size: 24px; }
  .pitch-card h3 { font-size: 16px; margin: 12px 0 8px; }
  .pitch-card p { font-size: 14px; color: var(--text-dim); margin: 0; line-height: 1.55; }
  @media (max-width: 980px) { .pitch-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .pitch-grid { grid-template-columns: 1fr; } }
</style>
